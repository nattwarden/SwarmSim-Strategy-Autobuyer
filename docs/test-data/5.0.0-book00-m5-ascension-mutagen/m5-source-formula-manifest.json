{
  "schemaVersion": "book00-m5-source-formula-manifest.v1",
  "purpose": "Pinned source facts for the advisor-only M5 Ascension and Mutagen implementation",
  "source": {
    "repository": "https://github.com/swarmsim/swarm",
    "commit": "06b4f404aa324a0b454348508cfa63d5c0f1ff54",
    "files": [
      "swarmsim-coffee/app/scripts/services/game.coffee",
      "swarmsim-coffee/app/scripts/services/effect.coffee",
      "swarmsim-coffee/app/scripts/services/unit.coffee",
