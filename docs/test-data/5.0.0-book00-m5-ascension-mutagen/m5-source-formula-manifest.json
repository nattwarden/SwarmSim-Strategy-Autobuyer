  "ascension": {
    "runtimeMethods": [
      "game.ascendEnergySpent()",
      "game.ascendCost()",
      "game.ascendCostPercent()",
      "game.ascendCostDurationSecs()"
    ],
    "costFormula": "ceil((1.12 ^ ascensionCount) * 5000000 / (2 ^ (spentEnergy / (50000 * mutagenAscendCostMultiplier))))",
    "warning": "The adjacent source comment says 20% per past ascension, but executable code uses Decimal.pow(1.12, ascends). Treat 1.12 as authoritative.",
    "legalWhen": "currentEnergy >= ascendCost",
    "onAscend": [
      "activeMutagen += inactivePremutagen",
      "inactivePremutagen = 0",
      "ascensionCount += 1",
      "grant one free respec when new ascensionCount is divisible by 3",
      "reset every unit without ascendPreserve to its init value",
      "reset every upgrade whose unit tab is not mutagen"
    ]
  },
  "mutagenEconomy": {
    "activeMutagenLarvaPerSecondPerUnit": 0.1,
    "inactivePremutagenBecomesActiveAtAscension": true,
    "mutationAllocationUnitCost": {
      "resource": "mutagen",
      "amountPerAllocatedUnit": 1
    },
    "mutationUnlockCost": {
      "resource": "mutagen",
      "formula": "15625 ^ alreadyUnlockedMutationCount",
      "base": 1,
      "factor": 15625,
      "mechanism": "Every unlock spends the geometric Mutagen cost, adds +1 mutagen.upgradecost, adds one mutatehidden level, and grants one unit of the corresponding mutation through addUnit. Later mutation levels cost one Mutagen each."
    },
    "allocationOpportunityCost": "Every active Mutagen spent on either an unlock or a later mutation level removes 0.1 larva/second from unallocated active-Mutagen production before considering the granted mutation benefit."
  },
  "effectTypes": {
    "logStat": {
      "formula": "1 + val3 * (log(val * level + val2) / log(val2) - 1)",
      "defaultVal3": 1,
      "verificationStatus": "source-verified"
    },
    "asympStat": {
      "formula": "1 + (val - 1) * (1 - 1 / (1 + level * val2))",
      "verificationStatus": "source-verified"
    },
    "expStat": {
      "formula": "1 + (level ^ val) * val2",
      "verificationStatus": "source-verified"
    },
    "initStat": {
      "formula": "multiply the current/default stat by val",
      "verificationStatus": "source-verified"
    }
  },
